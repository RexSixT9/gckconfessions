# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
# SWC compiler cache (Next.js)
/.swc/

# production
/build

# misc
.DS_Store
# Windows OS metadata
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all .env* EXCEPT template/example files
.env*
!.env.example
!.env.*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor settings (personal preferences should not be shared)
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-snippets
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
