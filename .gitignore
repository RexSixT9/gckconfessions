# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
**/coverage/
/playwright-report/
**/playwright-report/
/blob-report/
**/blob-report/
/test-results/
**/test-results/
/.lighthouseci/
**/.lighthouseci/
**/.playwright/
**/.nyc_output/
**/allure-results/
**/allure-report/

# next.js
/.next/
/out/
**/.next/
**/out/
# SWC compiler cache (Next.js)
/.swc/
**/.swc/
**/.turbo/
**/.cache/

# production
/build

# misc
.DS_Store
# Windows OS metadata
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# local analysis/test artifacts
build-output.txt
**/build-output*.txt
eslint-output*.txt
**/eslint-output*.txt
tsc-output*.txt
**/tsc-output*.txt
home-stress-report.json
ui-audit.json
tmp-*.js
**/tmp-*.js
**/tmp-*.ts

# env files — ignore all .env* EXCEPT template/example files
.env*
!.env.example
!.env.*.example

# vercel
.vercel
*.exe

# typescript
*.tsbuildinfo
next-env.d.ts

# editor settings (personal preferences should not be shared)
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-snippets
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
