DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_OWNER_ROLE_ID=
DISCORD_STATUS_CHANNEL_ID=
# Optional: if omitted, bot discovers or creates a status message automatically
DISCORD_STATUS_MESSAGE_ID=

# Internal metrics endpoint exposed by the web app
DISCORD_METRICS_URL=https://your-domain.com/api/internal/discord-metrics
DISCORD_METRICS_SECRET=

# Optional tuning
BOT_POLL_INTERVAL_MS=60000
BOT_DEFAULT_GRAPH_DAYS=7
BOT_WEBHOOK_WINDOW_HOURS=24
BOT_METRICS_TIMEOUT_MS=10000
BOT_METRICS_RETRY_ATTEMPTS=3
BOT_METRICS_RETRY_BASE_MS=700
BOT_REALTIME_HISTORY_POINTS=20
BOT_DASHBOARD_URL=https://your-domain.com/admin
BOT_TRANSPARENCY_URL=https://your-domain.com/transparency
BOT_HEADER_THUMBNAIL_URL=https://images-ext-1.discordapp.net/external/r0WHqs43ncBgD7HdmH2jWABxVe51DHgAH_MWh19K3h0/https/files.shapes.inc/562b3cc9.png
# Optional command visibility policy (comma-separated command names)
# Defaults: BOT_EPHEMERAL_COMMANDS=bot-health and BOT_PUBLIC_COMMANDS=status,queue,webhook-health
BOT_EPHEMERAL_COMMANDS=bot-health
BOT_PUBLIC_COMMANDS=status,queue,webhook-health

# Optional: use when DISCORD_METRICS_URL points to a Vercel deployment protected by a security checkpoint.
# Value should be your Protection Bypass for Automation secret from the Vercel project
# (often surfaced there as VERCEL_AUTOMATION_BYPASS_SECRET).
VERCEL_PROTECTION_BYPASS=
