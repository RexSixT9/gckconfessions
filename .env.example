# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT Secret (Generate a strong random string)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars

# Arcjet API Key for DDoS Protection
ARCJET_KEY=your-arcjet-api-key-here

# Admin Setup Key (For initial admin creation)
ADMIN_SETUP_KEY=your-secret-setup-key-here

# Environment
NODE_ENV=production

# Optional: IP Blocking (comma-separated list)
BLOCKED_IPS=

# Optional: Development IP Override
# DEV_IP_OVERRIDE=127.0.0.1

# Optional: Rate Limiting Override (for development)
# Set to "false" to disable rate limiting in development
# DISABLE_RATE_LIMIT=false

# Security Notes:
# 1. Never commit .env files to version control
# 2. Use strong, randomly generated secrets
# 3. Rotate JWT_SECRET periodically
# 4. Keep ADMIN_SETUP_KEY secret and change after setup
# 5. Enable all security features in production
