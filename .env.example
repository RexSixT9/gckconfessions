# Required runtime secrets
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# Optional fallback when SRV DNS lookups fail in your runtime/network:
# MONGODB_URI_DIRECT=mongodb://username:password@host1:27017,host2:27017,host3:27017/database?ssl=true&replicaSet=<replicaSet>&authSource=admin&retryWrites=true&w=majority
# IMPORTANT: replace host1/host2/host3, username/password, database, and replicaSet with real values.
JWT_SECRET=replace-with-strong-random-secret
ARCJET_KEY=replace-with-arcjet-key
ADMIN_SETUP_KEY=replace-with-setup-key

# Core app behavior
NEXT_PUBLIC_BASE_URL=http://localhost:3000
MAINTENANCE_MODE=off

# Optional quality-of-life toggles
NEXT_PUBLIC_CAMPAIGN_VARIANT=default
CSP_ENFORCE=false

# Optional advanced variables (only set when feature is used)
# ENABLE_REDIS_RATE_LIMITS=false
# REDIS_URL=redis://localhost:6379
# ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
# ADMIN_IP_ALLOWLIST=203.0.113.10,198.51.100.7
# REFERRER_POLICY=strict-origin-when-cross-origin
# PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=(), browsing-topics=(), fullscreen=(self)
# AUDIT_LOG_ENCRYPTION_KEY=
# CSP_REPORT_MAX_BYTES=16384
# DISCORD_AUDIT_WEBHOOK_URL=
# DISCORD_AUDIT_WEBHOOK_USERNAME=GCK Audit
# DISCORD_AUDIT_WEBHOOK_AVATAR_URL=
# BLOCKED_IPS=
# DEV_IP_OVERRIDE=
# CRON_SECRET=
# RETENTION_PENDING_DAYS=45
# RETENTION_REJECTED_DAYS=90
# RETENTION_AUDIT_DAYS=90
# RETENTION_AUDIT_HIGH_VOLUME_DAYS=14
# RETENTION_AUDIT_HIGH_VOLUME_ACTIONS=admin_session_checked,audit_webhook_delivered,security_alert_webhook_delivered,security_alert_email_delivered
# RETENTION_AUDIT_ANOMALY_DAYS=7
# RETENTION_AUDIT_ANOMALY_ACTIONS=security_alert,admin_login_failed,admin_setup_failed,audit_webhook_failed,security_alert_webhook_failed,security_alert_email_failed
# SECURITY_ALERT_TIMEOUT_MS=5000
# SECURITY_ALERT_MAX_RETRIES=2
# SECURITY_ALERT_DEDUPE_WINDOW_MS=60000
# AUDIT_WEBHOOK_TIMEOUT_MS=1800
# AUDIT_WEBHOOK_MAX_RETRIES=1
# AUDIT_WEBHOOK_BACKOFF_MS=120
# DISCORD_METRICS_SECRET=
# SECURITY_ALERT_WEBHOOK_URL=
# SECURITY_ALERT_WEBHOOK_AUTH=
# RESEND_API_KEY=
# SECURITY_ALERT_EMAIL_FROM=
# SECURITY_ALERT_EMAIL_TO=

# Optional Discord bot service variables (used in apps/discord-bot)
# DISCORD_BOT_TOKEN=
# DISCORD_CLIENT_ID=
# DISCORD_GUILD_ID=
# DISCORD_OWNER_ROLE_ID=
# DISCORD_STATUS_CHANNEL_ID=
# DISCORD_STATUS_MESSAGE_ID=
# DISCORD_METRICS_URL=http://localhost:3000/api/internal/discord-metrics
# BOT_POLL_INTERVAL_MS=20000
# BOT_DEFAULT_GRAPH_DAYS=7
# BOT_WEBHOOK_WINDOW_HOURS=24

# Test/CI only (normally set by runner)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001
# CI=true
