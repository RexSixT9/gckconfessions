# -------------------------------
# Base runtime
# -------------------------------
NODE_ENV=production

# -------------------------------
# Shared database
# -------------------------------
# Use separate credentials per app in production:
# - Public app user: write-only (confession ingest)
# - Admin app user: moderation/admin access
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# -------------------------------
# Public app required
# -------------------------------
ARCJET_KEY=your-arcjet-api-key

# Optional public controls
MAINTENANCE_MODE=off
CSP_ENFORCE=false
BLOCKED_IPS=
# DEV_IP_OVERRIDE=127.0.0.1

# Optional alert delivery
SECURITY_ALERT_WEBHOOK_URL=
SECURITY_ALERT_WEBHOOK_AUTH=
SECURITY_ALERT_EMAIL_FROM=
SECURITY_ALERT_EMAIL_TO=
SECURITY_ALERT_TIMEOUT_MS=5000
SECURITY_ALERT_MAX_RETRIES=2
SECURITY_ALERT_DEDUPE_WINDOW_MS=60000
CSP_REPORT_MAX_BYTES=16384

# -------------------------------
# Admin app required
# -------------------------------
# Generate a strong secret:
# openssl rand -base64 32
JWT_SECRET=replace-with-strong-secret-min-32-chars

# Rotate after initial setup and disable setup route in hardened prod workflows.
ADMIN_SETUP_KEY=replace-with-strong-setup-key
ADMIN_SETUP_ENABLED=false

# Restrict admin surface in production.
# Exact host only (include port for local dev values if needed).
# Example: admin.gckconfessions.com
ADMIN_ALLOWED_HOSTS=

# Optional hard IP allowlist for admin (comma separated).
# Example: 203.0.113.10,203.0.113.11
ADMIN_ALLOWED_IPS=

# Optional cookie domain for admin cookies.
# Keep empty to scope cookies to exact admin host.
# Example: admin.gckconfessions.com
ADMIN_COOKIE_DOMAIN=

# Optional admin/audit settings
AUDIT_LOG_ENCRYPTION_KEY=

# -------------------------------
# Deployment notes
# -------------------------------
# 1) Never commit .env files.
# 2) Use separate env var sets for public vs admin Vercel projects.
# 3) Use Production/Preview/Development env scopes in Vercel.
# 4) Rotate JWT_SECRET and ADMIN_SETUP_KEY periodically.
