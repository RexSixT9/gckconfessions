# ------------------------------------------------------------
# Core app configuration (required)
# ------------------------------------------------------------
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-random-32-plus-character-secret
ARCJET_KEY=replace-with-arcjet-key
ADMIN_SETUP_KEY=replace-with-admin-setup-key

# ------------------------------------------------------------
# Runtime + public metadata
# ------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://your-domain.example
NEXT_PUBLIC_CAMPAIGN_VARIANT=default

# ------------------------------------------------------------
# Submission flow controls
# ------------------------------------------------------------
MAINTENANCE_MODE=off

# hCaptcha is currently disabled in code, but these are used if enabled.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# ------------------------------------------------------------
# Rate-limit + request tuning
# ------------------------------------------------------------
BLOCKED_IPS=
DEV_IP_OVERRIDE=

# ------------------------------------------------------------
# Audit + security headers
# ------------------------------------------------------------
AUDIT_LOG_ENCRYPTION_KEY=
CSP_ENFORCE=false
CSP_REPORT_MAX_BYTES=16384

# ------------------------------------------------------------
# Maintenance cron endpoint
# ------------------------------------------------------------
CRON_SECRET=
RETENTION_PENDING_DAYS=45
RETENTION_REJECTED_DAYS=90

# ------------------------------------------------------------
# Security alerting (optional)
# ------------------------------------------------------------
SECURITY_ALERT_WEBHOOK_URL=
SECURITY_ALERT_WEBHOOK_AUTH=
RESEND_API_KEY=
SECURITY_ALERT_EMAIL_FROM=
SECURITY_ALERT_EMAIL_TO=
SECURITY_ALERT_TIMEOUT_MS=5000
SECURITY_ALERT_MAX_RETRIES=2
SECURITY_ALERT_DEDUPE_WINDOW_MS=60000

# ------------------------------------------------------------
# E2E testing (optional)
# ------------------------------------------------------------
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001

# Security notes:
# 1. Never commit populated .env files.
# 2. Use unique secrets per environment (dev/staging/prod).
# 3. Rotate JWT_SECRET, ADMIN_SETUP_KEY, and CRON_SECRET regularly.
# 4. Configure alerting variables before relying on incident notifications.
